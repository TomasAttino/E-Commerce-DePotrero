generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Team {
  id       String    @id @default(cuid())
  name     String
  slug     String    @unique
  banner   String
  products Product[]
}

model Product {
  id         String  @id @default(cuid())
  name       String
  price      Float
  image      String
  hoverImage String?
  sizes      String
  colors     String
  category   String
  inStock    Boolean @default(true)
  teamId     String
  team       Team    @relation(fields: [teamId], references: [id])
}
